# =============================================
# VSA COACHING INSTITUTE — .gitignore
# =============================================

# ----- Node / Backend -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Environment variables (NEVER commit secrets)
.env
.env.local
.env.development
.env.production
.env*.local

# ----- Build outputs -----
dist/
build/
.next/
out/

# ----- OS files -----
.DS_Store
Thumbs.db
desktop.ini

# ----- Editor / IDE -----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ----- Logs -----
logs/
*.log

# ----- Testing -----
coverage/
.nyc_output/

# ----- Misc -----
*.pem
*.key
*.cert